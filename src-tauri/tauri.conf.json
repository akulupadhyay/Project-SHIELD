{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Secure Portable Vault",
  "version": "0.1.0",
  "identifier": "com.darkrainbow.securevault",
  "build": {
    "frontendDist": "ui",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Secure Portable Vault",
        "url": "index.html",
        "width": 900,
        "height": 620,
        "minWidth": 720,
        "minHeight": 480,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": false,
        "scope": []
      },
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' data:",
        "font-src": "'self'",
        "connect-src": "'self' ipc: http://ipc.localhost",
        "object-src": "'none'",
        "base-uri": "'none'",
        "form-action": "'none'",
        "frame-ancestors": "'none'"
      },
      "freezePrototype": true,
      "dangerousDisableAssetCspModification": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Dark Rainbow",
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Encrypted portable SSD/HDD vault backend",
    "longDescription": "A Rust/Tauri IPC-only backend for encrypted portable storage with RBAC, audit logging, lockdown handling, and cryptographic erase.",
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
